# Pick ONE provider and fill its API key.
# All providers below are OpenAI-compatible chat/completions endpoints.

# === DeepSeek (recommended default — V4 Flash is the best price/quality
#     for English -> Chinese podcast summarization) ===
LLM_PROVIDER=deepseek
# Paste your key here, or set DEEPSEEK_API_KEY in your shell.
# LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
# Use deepseek-v4-pro instead if you need deeper reasoning (slower, ~3x cost).

# === Kimi / Moonshot ===
# LLM_PROVIDER=kimi
# LLM_API_KEY=your_kimi_api_key_here
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-128k

# === Zhipu GLM ===
# LLM_PROVIDER=glm
# LLM_API_KEY=your_glm_api_key_here
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# === Alibaba Qwen / DashScope ===
# LLM_PROVIDER=qwen
# LLM_API_KEY=your_qwen_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# === OpenAI, or any OpenAI-compatible provider ===
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Optional SOCKS5 proxy for YouTube/RSS access.
# PODCAST_PROXY=socks5://127.0.0.1:1080

# Whisper auto-transcription is configured in pod2wiki.config.yaml under the
# `whisper:` block (model, clip_seconds, auto_threshold). Requires the optional
# `faster-whisper` Python package and `ffmpeg` on PATH; the run degrades to the
# RSS description if either is missing.
